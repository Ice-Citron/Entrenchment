# Resolve a name or number to a layout name
_resolve_name() {
    local input="$1"
    [[ -z "$input" ]] && { echo ""; return; }

    # If it is a number, look up from _LAYOUT_NAMES
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        local idx=$((input - 1))
        if [[ $idx -ge 0 && $idx -lt ${#_LAYOUT_NAMES[@]} ]]; then
            echo "${_LAYOUT_NAMES[$idx]}"
            return
        else
            echo ""
            return
        fi
    fi

    # Otherwise treat as a name — check if file exists
    if [[ -f "${LAYOUT_DIR}/${input}.json" ]]; then
        echo "$input"
    else
        echo ""
    fi
}

