# ============================================================================
# INTERACTIVE: REPL mode when run with no arguments
# ============================================================================
do_interactive() {
    clear
    echo -e "${BOLD}┌─────────────────────────────────────────┐${NC}"
    echo -e "${BOLD}│   Workspace Layout Manager              │${NC}"
    echo -e "${BOLD}└─────────────────────────────────────────┘${NC}"
    echo ""

    # Show current screens
    local screen_count
    screen_count=$(/usr/bin/python3 -c "
import subprocess, json
r = subprocess.run(['system_profiler', 'SPDisplaysDataType', '-json'], capture_output=True, text=True)
data = json.loads(r.stdout)
count = 0
for gpu in data.get('SPDisplaysDataType', []):
    count += len(gpu.get('spdisplays_ndrvs', []))
print(count)
" 2>/dev/null || echo "?")
    echo -e "  ${CYAN}Screens:${NC} ${screen_count} connected"
    echo ""

    # Show saved layouts as numbered list
    _list_numbered

    echo ""
    echo -e "  ${BOLD}Commands:${NC}"
    echo -e "    ${GREEN}save${NC} <name> [desc]     Save current layout"
    echo -e "    ${GREEN}restore${NC} <name|#>       Restore a layout (by name or number)"
    echo -e "    ${GREEN}info${NC} <name|#>          Show layout details"
    echo -e "    ${GREEN}delete${NC} <name|#>        Delete a layout"
    echo -e "    ${GREEN}screens${NC}                Show display info"
    echo -e "    ${GREEN}list${NC}                   Refresh layout list"
    echo -e "    ${GREEN}help${NC}                   Show commands"
    echo -e "    ${GREEN}quit${NC} / ${GREEN}q${NC} / ${GREEN}Ctrl-C${NC}      Exit"
    echo ""

    # REPL loop
    while true; do
        echo -ne "${BOLD}layout>${NC} "
        read -r line || { echo ""; break; }  # handle Ctrl-D

        # Trim whitespace
        line=$(echo "$line" | xargs 2>/dev/null || echo "$line")
        [[ -z "$line" ]] && continue

        # Parse command and arguments
        local cmd arg1 arg_rest
        cmd=$(echo "$line" | awk '{print $1}')
        arg1=$(echo "$line" | awk '{print $2}')
        arg_rest=$(echo "$line" | sed 's/^[^ ]* *[^ ]* *//')

        case "$cmd" in
            save|s)
                if [[ -z "$arg1" ]]; then
                    echo -ne "  Layout name: "
                    read -r arg1
                    [[ -z "$arg1" ]] && { echo -e "  ${RED}Cancelled.${NC}"; continue; }
                    echo -ne "  Description (optional): "
                    read -r arg_rest
                fi
                echo ""
                do_save "$arg1" "$arg_rest"
                echo ""
                ;;
            restore|r)
                local target
                target=$(_resolve_name "$arg1")
                if [[ -z "$target" ]]; then
                    echo -e "  ${RED}Layout not found.${NC}"
                    continue
                fi
                echo ""
                do_restore "$target"
                echo ""
                ;;
            info|i)
                local target
                target=$(_resolve_name "$arg1")
                if [[ -z "$target" ]]; then
                    echo -e "  ${RED}Layout not found.${NC}"
                    continue
                fi
                echo ""
                do_info "$target"
                echo ""
                ;;
            delete|rm|d)
                local target
                target=$(_resolve_name "$arg1")
                if [[ -z "$target" ]]; then
                    echo -e "  ${RED}Layout not found.${NC}"
                    continue
                fi
                echo -ne "  ${YELLOW}Delete '${target}'? [y/N]:${NC} "
                read -r confirm
                if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
                    do_delete "$target"
                else
                    echo -e "  Cancelled."
                fi
                echo ""
                ;;
            screens|displays)
                echo ""
                do_screens
                echo ""
                ;;
            list|ls|l)
                echo ""
                _list_numbered
                echo ""
                ;;
            help|h|?)
                echo ""
                echo -e "  ${BOLD}Commands:${NC}"
                echo -e "    ${GREEN}save${NC} <name> [desc]     Save current layout"
                echo -e "    ${GREEN}restore${NC} <name|#>       Restore a layout (by name or number)"
                echo -e "    ${GREEN}info${NC} <name|#>          Show layout details"
                echo -e "    ${GREEN}delete${NC} <name|#>        Delete a layout"
                echo -e "    ${GREEN}screens${NC}                Show display info"
                echo -e "    ${GREEN}list${NC}                   Refresh layout list"
                echo -e "    ${GREEN}quit${NC} / ${GREEN}q${NC} / ${GREEN}Ctrl-C${NC}      Exit"
                echo ""
                echo -e "  Tip: Use a number instead of a name (e.g. ${BOLD}restore 1${NC})"
                echo ""
                ;;
            quit|q|exit)
                echo -e "  ${CYAN}Bye!${NC}"
                exit 0
                ;;
            *)
                echo -e "  ${RED}Unknown command:${NC} $cmd (type ${BOLD}help${NC} for commands)"
                ;;
        esac
    done
}

# Print numbered list of saved layouts. Also populates _LAYOUT_NAMES array.
