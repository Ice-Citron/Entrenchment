#!/bin/bash
# ============================================================================
# Workspace Layout Manager
# Save and restore your multi-monitor window layouts across different contexts
# (e.g., Isaac Sim project vs. Computer Architecture revision)
#
# Usage:
#   layout save <name> [--description "..."]
#   layout restore <name>
#   layout list
#   layout delete <name>
#   layout info <name>
#   layout screens
# ============================================================================

set -euo pipefail

LAYOUT_DIR="${HOME}/.config/workspace-layouts"
mkdir -p "$LAYOUT_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# ============================================================================
# SAVE: Capture current window layout
# ============================================================================
do_save() {
    local name="$1"
    local description="${2:-}"
    local layout_file="${LAYOUT_DIR}/${name}.json"

    # Create temp directory for intermediate JSON files
    local tmp_dir
    tmp_dir=$(mktemp -d)
    trap "rm -rf '$tmp_dir'" EXIT

    echo -e "${CYAN}📸 Capturing workspace layout: ${BOLD}${name}${NC}"

    # Get screen info
    echo -e "${BLUE}  → Detecting displays...${NC}"
    local screens
    screens=$(osascript -l JavaScript << 'JSEOF'
const app = Application.currentApplication();
app.includeStandardAdditions = true;
const screens = [];
// Use AppKit via ObjC bridge to get screen info
ObjC.import('AppKit');
const nsScreens = $.NSScreen.screens;
for (let i = 0; i < nsScreens.count; i++) {
    const s = nsScreens.objectAtIndex(i);
    const frame = s.frame;
    const vframe = s.visibleFrame;
    screens.push({
        index: i,
        x: frame.origin.x,
        y: frame.origin.y,
        width: frame.size.width,
        height: frame.size.height,
        visibleX: vframe.origin.x,
        visibleY: vframe.origin.y,
        visibleWidth: vframe.size.width,
        visibleHeight: vframe.size.height
    });
}
JSON.stringify(screens);
JSEOF
    )
    echo "$screens" > "$tmp_dir/screens.json"
    local screen_count
    screen_count=$(/usr/bin/python3 -c "import sys,json; print(len(json.loads(open('$tmp_dir/screens.json').read())))")
    echo -e "${GREEN}  ✓ Found ${screen_count} display(s)${NC}"

    # Capture Finder windows (including tabs within each window)
    echo -e "${BLUE}  → Capturing Finder windows...${NC}"
    local finder_windows
    finder_windows=$(osascript -l JavaScript << 'JSEOF'
const finder = Application("Finder");
const se = Application("System Events");
const windows = [];
try {
    const fWindows = finder.finderWindows();
    for (let i = 0; i < fWindows.length; i++) {
        const w = fWindows[i];
        try {
            const bounds = w.bounds();
            const target = w.target();
            let path = "";
            try {
                path = decodeURI(target.url()).replace("file://", "");
            } catch(e) {}

            // Capture all tabs in this Finder window
            // Finder scripting does not directly expose tabs, so we use
            // the current target as the primary path and try to detect
            // tab count via System Events UI elements
            const tabs = [{path: path, name: w.name()}];

            // Try to get Finder tab info via System Events
            try {
                const finderProc = se.processes.byName("Finder");
                const uiWin = finderProc.windows[i];
                // Finder tabs live in a tab group in the toolbar
                const tabGroups = uiWin.tabGroups();
                if (tabGroups.length > 0) {
                    const tabGroup = tabGroups[0];
                    const uiTabs = tabGroup.radioButtons();
                    if (uiTabs.length > 1) {
                        // Multiple tabs detected - we got the active one above
                        // Record tab count so restore knows to expect multiple
                        tabs[0].tabCount = uiTabs.length;
                        tabs[0].tabNames = [];
                        for (let t = 0; t < uiTabs.length; t++) {
                            tabs[0].tabNames.push(uiTabs[t].title());
                        }
                    }
                }
            } catch(tabErr) {}

            windows.push({
                app: "Finder",
                name: w.name(),
                path: path,
                tabs: tabs,
                bounds: {
                    x: bounds.x,
                    y: bounds.y,
                    width: bounds.width,
                    height: bounds.height
                }
            });
        } catch(e) {}
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$finder_windows" > "$tmp_dir/finder.json"
    local finder_count
    finder_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/finder.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${finder_count} Finder window(s)${NC}"

    # Capture iTerm2 windows
    echo -e "${BLUE}  → Capturing iTerm2 windows...${NC}"
    local iterm_windows
    iterm_windows=$(osascript -l JavaScript << 'JSEOF'
const windows = [];
try {
    const iterm = Application("iTerm2");
    const iWindows = iterm.windows();
    for (let i = 0; i < iWindows.length; i++) {
        const w = iWindows[i];
        try {
            const bounds = w.bounds();
            const tabs = [];
            const wTabs = w.tabs();
            for (let t = 0; t < wTabs.length; t++) {
                const tab = wTabs[t];
                try {
                    const sessions = tab.sessions();
                    const sessionData = [];
                    for (let s = 0; s < sessions.length; s++) {
                        const sess = sessions[s];
                        try {
                            // Try to get the current working directory via tty
                            let cwd = "";
                            try {
                                const tty = sess.tty();
                                const app2 = Application.currentApplication();
                                app2.includeStandardAdditions = true;
                                // Use lsof to find the cwd of the foreground process
                                cwd = app2.doShellScript("lsof -p $(lsof -t " + tty + " | tail -1) -Fn 2>/dev/null | grep '^ncwd' | head -1 | cut -c5- || echo ''");
                            } catch(e2) {}
                            sessionData.push({
                                name: sess.name(),
                                profileName: sess.profileName(),
                                cwd: cwd
                            });
                        } catch(e3) {}
                    }
                    tabs.push({
                        name: tab.currentSession().name(),
                        sessions: sessionData
                    });
                } catch(e4) {}
            }
            windows.push({
                app: "iTerm2",
                name: w.name(),
                bounds: {
                    x: bounds.x,
                    y: bounds.y,
                    width: bounds.width - bounds.x,
                    height: bounds.height - bounds.y
                },
                boundsRaw: bounds,
                tabs: tabs
            });
        } catch(e5) {}
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$iterm_windows" > "$tmp_dir/iterm.json"
    local iterm_count
    iterm_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/iterm.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${iterm_count} iTerm2 window(s)${NC}"

    # Capture Brave Browser windows (all tabs + attempt tab group info)
    echo -e "${BLUE}  → Capturing Brave Browser windows...${NC}"

    # First, try to extract tab group info from Brave's Preferences file
    local brave_tab_groups="[]"
    local brave_prefs="${HOME}/Library/Application Support/BraveSoftware/Brave-Browser/Default/Preferences"
    if [[ -f "$brave_prefs" ]]; then
        brave_tab_groups=$(/usr/bin/python3 -c "
import json
try:
    with open('$brave_prefs', 'r') as f:
        prefs = json.load(f)
    # Tab groups are stored in session data, try to extract group metadata
    groups = prefs.get('tab_group_metadata', {}).get('groups', {})
    result = []
    for gid, gdata in groups.items():
        result.append({
            'id': gid,
            'title': gdata.get('title', ''),
            'color': gdata.get('color', 0)
        })
    print(json.dumps(result))
except:
    print('[]')
" 2>/dev/null || echo "[]")
    fi
    echo "$brave_tab_groups" > "$tmp_dir/brave_tab_groups.json"

    local brave_windows
    brave_windows=$(osascript -l JavaScript << 'JSEOF'
const windows = [];
try {
    const brave = Application("Brave Browser");
    const bWindows = brave.windows();
    for (let i = 0; i < bWindows.length; i++) {
        const w = bWindows[i];
        try {
            const bounds = w.bounds();
            const tabs = [];
            const wTabs = w.tabs();
            for (let t = 0; t < wTabs.length; t++) {
                const tab = wTabs[t];
                try {
                    tabs.push({
                        title: tab.title(),
                        url: tab.url(),
                        index: t
                    });
                } catch(e2) {}
            }
            windows.push({
                app: "Brave Browser",
                name: w.name(),
                bounds: {
                    x: bounds.x,
                    y: bounds.y,
                    width: bounds.width - bounds.x,
                    height: bounds.height - bounds.y
                },
                boundsRaw: bounds,
                tabs: tabs,
                activeTabIndex: w.activeTabIndex()
            });
        } catch(e3) {}
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$brave_windows" > "$tmp_dir/brave.json"
    local brave_count
    brave_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/brave.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${brave_count} Brave Browser window(s)${NC}"

    # Capture VS Code windows using CoreGraphics + VS Code internal state
    # This avoids System Events Accessibility permission requirements
    echo -e "${BLUE}  → Capturing VS Code windows...${NC}"

    python3 - "$tmp_dir" << 'VSCODE_CAPTURE_PY'
import json, os, sys, subprocess, urllib.parse

tmp_dir = sys.argv[1]
windows = []

# --- Step 1: Get VS Code window bounds via CoreGraphics ---
# CGWindowListCopyWindowInfo works without Accessibility permission
try:
    import Quartz
    all_windows = Quartz.CGWindowListCopyWindowInfo(
        Quartz.kCGWindowListOptionAll | Quartz.kCGWindowListExcludeDesktopElements,
        Quartz.kCGNullWindowID
    )
    code_pid = None
    # Find the main Code process PID
    for w in all_windows:
        if w.get("kCGWindowOwnerName") == "Code":
            code_pid = w.get("kCGWindowOwnerPID")
            break

    if code_pid:
        # Filter to actual content windows (not toolbars, menubars, popups)
        # Real VS Code windows have substantial height (> 200px)
        for w in all_windows:
            if w.get("kCGWindowOwnerPID") != code_pid:
                continue
            if w.get("kCGWindowLayer", -1) != 0:
                continue
            bounds = w.get("kCGWindowBounds", {})
            height = bounds.get("Height", 0)
            width = bounds.get("Width", 0)
            # Skip toolbars (< 100px tall), tiny popups, and zero-size windows
            if height < 200 or width < 200:
                continue
            name = w.get("kCGWindowName", "") or ""
            windows.append({
                "app": "Visual Studio Code",
                "name": name,
                "workspace": "",
                "bounds": {
                    "x": int(bounds.get("X", 0)),
                    "y": int(bounds.get("Y", 0)),
                    "width": int(width),
                    "height": int(height)
                }
            })
except ImportError:
    # Quartz not available — try osascript as fallback
    try:
        r = subprocess.run(["osascript", "-l", "JavaScript", "-e", """
        const windows = [];
        try {
            const se = Application("System Events");
            const p = se.processes.byName("Code");
            const ws = p.windows();
            for (let i = 0; i < ws.length; i++) {
                const w = ws[i];
                windows.push({
                    app: "Visual Studio Code",
                    name: w.title(),
                    workspace: "",
                    bounds: {x: w.position()[0], y: w.position()[1], width: w.size()[0], height: w.size()[1]}
                });
            }
        } catch(e) {}
        JSON.stringify(windows);
        """], capture_output=True, text=True, timeout=10)
        if r.stdout.strip():
            windows = json.loads(r.stdout.strip())
    except:
        pass

# --- Step 2: Get workspace info from VS Code internal state ---
folder_map = {}  # folder_name -> folder_path
open_workspaces = []  # ordered list of open workspace paths

# Read storage.json for currently open windows
storage_path = os.path.expanduser("~/Library/Application Support/Code/storage.json")
if os.path.exists(storage_path):
    try:
        with open(storage_path) as f:
            data = json.load(f)
        # openedWindows has the currently open windows with folder URIs
        for entry in data.get("openedWindows", []):
            folder_uri = entry.get("folderUri", "")
            remote_auth = entry.get("remoteAuthority", "")
            if folder_uri.startswith("file://"):
                path = urllib.parse.unquote(folder_uri.replace("file://", ""))
                name = os.path.basename(path)
                folder_map[name] = path
                open_workspaces.append({"name": name, "path": path, "remote": ""})
            elif folder_uri.startswith("vscode-remote://"):
                # Remote SSH workspace: vscode-remote://ssh-remote+host/path
                parts = folder_uri.replace("vscode-remote://", "").split("/", 1)
                if len(parts) >= 2:
                    path = "/" + parts[1]
                    name = os.path.basename(path)
                    folder_map[name] = path
                    open_workspaces.append({"name": name, "path": path, "remote": remote_auth or parts[0]})
        # Also check lastActiveWindow
        last = data.get("lastActiveWindow", {})
        folder_uri = last.get("folderUri", "")
        if folder_uri.startswith("file://"):
            path = urllib.parse.unquote(folder_uri.replace("file://", ""))
            name = os.path.basename(path)
            folder_map[name] = path
        elif folder_uri.startswith("vscode-remote://"):
            parts = folder_uri.replace("vscode-remote://", "").split("/", 1)
            if len(parts) >= 2:
                path = "/" + parts[1]
                name = os.path.basename(path)
                folder_map[name] = path
    except:
        pass

# Scan workspaceStorage as additional source
ws_storage = os.path.expanduser("~/Library/Application Support/Code/User/workspaceStorage")
if os.path.isdir(ws_storage):
    try:
        for entry in os.listdir(ws_storage):
            ws_json = os.path.join(ws_storage, entry, "workspace.json")
            if os.path.exists(ws_json):
                try:
                    with open(ws_json) as f:
                        ws_data = json.load(f)
                    folder = ws_data.get("folder", "")
                    if folder.startswith("file://"):
                        path = urllib.parse.unquote(folder.replace("file://", ""))
                        name = os.path.basename(path)
                        folder_map[name] = path
                    elif folder.startswith("vscode-remote://"):
                        parts = folder.replace("vscode-remote://", "").split("/", 1)
                        if len(parts) >= 2:
                            path = "/" + parts[1]
                            name = os.path.basename(path)
                            folder_map[name] = path
                except:
                    pass
    except:
        pass

# --- Step 3: Enrich windows with workspace info ---
# Try to extract workspace from window title (if Screen Recording gave us titles)
for w in windows:
    title = w.get("name", "")
    if title and " \u2014 " in title:
        parts = title.split(" \u2014 ")
        if len(parts) >= 2:
            ws = parts[-2].strip()
            # Strip SSH suffix like "[SSH: hostname]"
            import re
            ws = re.sub(r"\s*\[SSH:.*?\]\s*$", "", ws)
            w["workspace"] = ws
            if ws in folder_map:
                w["workspacePath"] = folder_map[ws]
            else:
                for key, path in folder_map.items():
                    if key.lower() == ws.lower() or os.path.basename(path).lower() == ws.lower():
                        w["workspacePath"] = path
                        break

# If titles are empty (no Screen Recording), match windows to open workspaces by count
if windows and all(not w.get("name") for w in windows):
    if len(open_workspaces) == len(windows):
        for w, ws_info in zip(windows, open_workspaces):
            w["workspace"] = ws_info["name"]
            w["workspacePath"] = ws_info["path"]
            if ws_info.get("remote"):
                w["remote"] = ws_info["remote"]
    elif open_workspaces:
        # Best effort: assign what we can
        for i, w in enumerate(windows):
            if i < len(open_workspaces):
                w["workspace"] = open_workspaces[i]["name"]
                w["workspacePath"] = open_workspaces[i]["path"]
                if open_workspaces[i].get("remote"):
                    w["remote"] = open_workspaces[i]["remote"]

# Write folder map and final windows
with open(os.path.join(tmp_dir, "vscode_folder_map.json"), "w") as f:
    json.dump(folder_map, f)
with open(os.path.join(tmp_dir, "vscode.json"), "w") as f:
    json.dump(windows, f)
VSCODE_CAPTURE_PY

    local vscode_count
    vscode_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/vscode.json').read())))" 2>/dev/null || echo "0")
    echo -e "${GREEN}  ✓ Captured ${vscode_count} VS Code window(s)${NC}"

    # Capture Preview (PDF viewer) windows
    echo -e "${BLUE}  → Capturing Preview windows...${NC}"
    local preview_windows
    preview_windows=$(osascript -l JavaScript << 'JSEOF'
const windows = [];
try {
    const preview = Application("Preview");
    const pWindows = preview.windows();
    for (let i = 0; i < pWindows.length; i++) {
        const w = pWindows[i];
        try {
            const bounds = w.bounds();
            let docPath = "";
            try {
                const doc = w.document();
                docPath = doc.path();
            } catch(e2) {}
            windows.push({
                app: "Preview",
                name: w.name(),
                path: docPath || "",
                bounds: {
                    x: bounds.x,
                    y: bounds.y,
                    width: bounds.width - bounds.x,
                    height: bounds.height - bounds.y
                },
                boundsRaw: bounds
            });
        } catch(e3) {}
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$preview_windows" > "$tmp_dir/preview.json"
    local preview_count
    preview_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/preview.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${preview_count} Preview window(s)${NC}"

    # Capture Microsoft Remote Desktop windows
    echo -e "${BLUE}  → Capturing Remote Desktop windows...${NC}"
    local rdp_windows
    rdp_windows=$(osascript -l JavaScript << 'JSEOF'
const windows = [];
try {
    const se = Application("System Events");
    // Try "Microsoft Remote Desktop" or "Windows App"
    let procName = "";
    try {
        se.processes.byName("Microsoft Remote Desktop").exists();
        procName = "Microsoft Remote Desktop";
    } catch(e) {
        try {
            se.processes.byName("Windows App").exists();
            procName = "Windows App";
        } catch(e2) {}
    }
    if (procName) {
        const proc = se.processes.byName(procName);
        const rdpWindows = proc.windows();
        for (let i = 0; i < rdpWindows.length; i++) {
            const w = rdpWindows[i];
            try {
                const pos = w.position();
                const sz = w.size();
                windows.push({
                    app: procName,
                    name: w.title(),
                    bounds: {
                        x: pos[0],
                        y: pos[1],
                        width: sz[0],
                        height: sz[1]
                    }
                });
            } catch(e3) {}
        }
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$rdp_windows" > "$tmp_dir/rdp.json"
    local rdp_count
    rdp_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/rdp.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${rdp_count} Remote Desktop window(s)${NC}"

    # Capture generic other windows via System Events
    echo -e "${BLUE}  → Capturing other app windows...${NC}"
    local other_windows
    other_windows=$(osascript -l JavaScript << 'JSEOF'
const windows = [];
const skipApps = new Set([
    "Finder", "iTerm2", "Brave Browser", "Code",
    "Microsoft Remote Desktop", "Windows App", "Preview",
    "Dock", "SystemUIServer", "Window Manager", "Control Center",
    "Notification Center", "WindowManager", "universalAccessAuthWarn",
    "Spotlight", "AXVisualSupportAgent", "TextInputMenuAgent",
    "TextInputSwitcher", "loginwindow", "Claude"
]);
try {
    const se = Application("System Events");
    const procs = se.processes.whose({backgroundOnly: false})();
    for (let p = 0; p < procs.length; p++) {
        const proc = procs[p];
        const procName = proc.name();
        if (skipApps.has(procName)) continue;
        try {
            const pWindows = proc.windows();
            for (let i = 0; i < pWindows.length; i++) {
                const w = pWindows[i];
                try {
                    const pos = w.position();
                    const sz = w.size();
                    if (sz[0] > 50 && sz[1] > 50) { // Skip tiny windows
                        windows.push({
                            app: procName,
                            name: w.title() || w.name() || "",
                            bounds: {
                                x: pos[0],
                                y: pos[1],
                                width: sz[0],
                                height: sz[1]
                            }
                        });
                    }
                } catch(e2) {}
            }
        } catch(e3) {}
    }
} catch(e) {}
JSON.stringify(windows);
JSEOF
    )
    echo "$other_windows" > "$tmp_dir/other.json"
    local other_count
    other_count=$(/usr/bin/python3 -c "import json; print(len(json.loads(open('$tmp_dir/other.json').read())))")
    echo -e "${GREEN}  ✓ Captured ${other_count} other window(s)${NC}"

    # Also try to capture VS Code recent workspaces for smarter restore
    echo -e "${BLUE}  → Capturing VS Code workspace paths...${NC}"
    local vscode_workspaces="[]"
    local vscode_storage="${HOME}/Library/Application Support/Code/storage.json"
    if [[ -f "$vscode_storage" ]]; then
        vscode_workspaces=$(/usr/bin/python3 -c "
import json, sys, os
try:
    with open(os.path.expanduser('$vscode_storage'), 'r') as f:
        data = json.load(f)
    # Extract recent opened paths
    recent = data.get('openedPathsList', {}).get('workspaces3', [])
    # Only keep file:// paths and convert
    paths = []
    for r in recent[:20]:
        if isinstance(r, str) and r.startswith('file://'):
            paths.append(r.replace('file://', ''))
        elif isinstance(r, dict) and 'configPath' in r:
            p = r['configPath']
            if p.startswith('file://'):
                paths.append(p.replace('file://', ''))
    print(json.dumps(paths))
except:
    print('[]')
" 2>/dev/null || echo "[]")
    fi
    echo -e "${GREEN}  ✓ Done${NC}"

    # Write vscode workspaces to temp file too
    echo "$vscode_workspaces" > "$tmp_dir/vscode_workspaces.json"

    # Assemble the full layout JSON
    echo -e "${BLUE}  → Saving layout...${NC}"
    /usr/bin/python3 << PYEOF
import json, datetime, os

tmp = "$tmp_dir"

def load(filename):
    with open(os.path.join(tmp, filename)) as f:
        return json.loads(f.read())

layout = {
    "name": "$name",
    "description": "$description",
    "savedAt": datetime.datetime.now().isoformat(),
    "screenCount": len(load("screens.json")),
    "screens": load("screens.json"),
    "windows": {
        "finder": load("finder.json"),
        "iterm": load("iterm.json"),
        "brave": load("brave.json"),
        "vscode": load("vscode.json"),
        "preview": load("preview.json"),
        "rdp": load("rdp.json"),
        "other": load("other.json")
    },
    "vscodeRecentWorkspaces": load("vscode_workspaces.json"),
    "braveTabGroups": load("brave_tab_groups.json")
}

with open("$layout_file", "w") as f:
    json.dump(layout, f, indent=2)

total = sum(len(v) for v in layout["windows"].values())
print(f"Saved {total} windows across {layout['screenCount']} screen(s)")
PYEOF

    echo -e "${GREEN}✅ Layout '${name}' saved to ${layout_file}${NC}"
    echo ""
}


# ============================================================================
# RESTORE: Reopen and reposition all windows
# ============================================================================
do_restore() {
    local name="$1"
    local layout_file="${LAYOUT_DIR}/${name}.json"

    if [[ ! -f "$layout_file" ]]; then
        echo -e "${RED}❌ Layout '${name}' not found.${NC}"
        echo -e "Available layouts:"
        do_list
        exit 1
    fi

    echo -e "${CYAN}🔄 Restoring workspace layout: ${BOLD}${name}${NC}"

    /usr/bin/python3 << 'PYEOF'
import json, subprocess, time, sys, os

layout_file = sys.argv[1] if len(sys.argv) > 1 else os.environ.get("LAYOUT_FILE", "")

PYEOF

    # Use Python + osascript for the restore logic
    /usr/bin/python3 << PYEOF
import json, subprocess, time, os

layout_file = "$layout_file"
with open(layout_file) as f:
    layout = json.load(f)

def run_osascript(script):
    """Run AppleScript and return output."""
    try:
        result = subprocess.run(
            ["osascript", "-e", script],
            capture_output=True, text=True, timeout=15
        )
        return result.stdout.strip()
    except:
        return ""

def run_jxa(script):
    """Run JXA (JavaScript for Automation) and return output."""
    try:
        result = subprocess.run(
            ["osascript", "-l", "JavaScript", "-e", script],
            capture_output=True, text=True, timeout=15
        )
        return result.stdout.strip()
    except:
        return ""

# Current screen count
current_screens = int(run_jxa("""
ObjC.import('AppKit');
$.NSScreen.screens.count;
""") or "1")

saved_screens = layout.get("screenCount", 1)
if current_screens != saved_screens:
    print(f"⚠️  Warning: Layout was saved with {saved_screens} screen(s), but you have {current_screens}. Windows may need manual adjustment.")
    print()

# --- Restore Finder windows ---
finder_windows = layout["windows"].get("finder", [])
if finder_windows:
    print(f"📁 Restoring {len(finder_windows)} Finder window(s)...")
    # Close existing Finder windows first
    run_osascript('tell application "Finder" to close every window')
    time.sleep(0.5)

    for fw in finder_windows:
        path = fw.get("path", "")
        b = fw.get("bounds", {})
        if path:
            # Open the folder and set bounds
            script = f'''
            tell application "Finder"
                try
                    set targetFolder to POSIX file "{path}" as alias
                    set newWindow to make new Finder window to targetFolder
                    set bounds of newWindow to {{{b.get("x",0)}, {b.get("y",0)}, {b.get("x",0) + b.get("width",800)}, {b.get("y",0) + b.get("height",600)}}}
                end try
            end tell
            '''
            run_osascript(script)
            time.sleep(0.3)
    print("  ✓ Finder windows restored")

# --- Restore iTerm2 windows ---
iterm_windows = layout["windows"].get("iterm", [])
if iterm_windows:
    print(f"🖥️  Restoring {len(iterm_windows)} iTerm2 window(s)...")
    # Launch iTerm if not running
    run_osascript('tell application "iTerm" to activate')
    time.sleep(1)

    for idx, iw in enumerate(iterm_windows):
        b = iw.get("boundsRaw", iw.get("bounds", {}))
        tabs = iw.get("tabs", [])

        if idx == 0:
            # Use the existing window for the first one
            script = f'''
            tell application "iTerm"
                tell current window
                    set bounds to {{{b.get("x", b.get("x",0))}, {b.get("y", b.get("y",0))}, {b.get("width", b.get("x",0) + 800)}, {b.get("height", b.get("y",0) + 600)}}}
                end tell
            end tell
            '''
        else:
            script = f'''
            tell application "iTerm"
                set newWindow to (create window with default profile)
                set bounds of newWindow to {{{b.get("x", 0)}, {b.get("y", 0)}, {b.get("width", 800)}, {b.get("height", 600)}}}
            end tell
            '''
        run_osascript(script)
        time.sleep(0.5)

        # Restore tabs with their working directories
        for t_idx, tab in enumerate(tabs):
            sessions = tab.get("sessions", [])
            if sessions:
                cwd = sessions[0].get("cwd", "")
                if cwd and os.path.isdir(cwd):
                    if t_idx == 0 and idx == 0:
                        # First tab of first window - use current session
                        run_osascript(f'''
                        tell application "iTerm"
                            tell current session of current window
                                write text "cd {cwd}"
                            end tell
                        end tell
                        ''')
                    elif t_idx > 0:
                        # Additional tab in same window
                        run_osascript(f'''
                        tell application "iTerm"
                            tell current window
                                set newTab to (create tab with default profile)
                                tell current session of newTab
                                    write text "cd {cwd}"
                                end tell
                            end tell
                        end tell
                        ''')
                    elif idx > 0 and t_idx == 0:
                        # First tab of subsequent window
                        run_osascript(f'''
                        tell application "iTerm"
                            tell window {idx + 1}
                                tell current session
                                    write text "cd {cwd}"
                                end tell
                            end tell
                        end tell
                        ''')
                    time.sleep(0.2)
    print("  ✓ iTerm2 windows restored")

# --- Restore Brave Browser windows ---
brave_windows = layout["windows"].get("brave", [])
if brave_windows:
    print(f"🌐 Restoring {len(brave_windows)} Brave Browser window(s)...")
    run_osascript('tell application "Brave Browser" to activate')
    time.sleep(1)

    for idx, bw in enumerate(brave_windows):
        tabs = bw.get("tabs", [])
        active_idx = bw.get("activeTabIndex", 1)

        if idx == 0 and tabs:
            # Use the existing frontmost window for the first saved window
            first_url = tabs[0].get("url", "about:blank")
            run_jxa(f'''
            const brave = Application("Brave Browser");
            const w = brave.windows[0];
            w.activeTab.url = "{first_url}";
            ''')
            time.sleep(0.3)
            for tab in tabs[1:]:
                url = tab.get("url", "about:blank")
                run_jxa(f'''
                const brave = Application("Brave Browser");
                const w = brave.windows[0];
                brave.Tab({{url: "{url}"}}).make({{at: w}});
                ''')
                time.sleep(0.2)
        elif tabs:
            # Create a new window for each additional saved window
            first_url = tabs[0].get("url", "about:blank")
            run_jxa(f'''
            const brave = Application("Brave Browser");
            brave.Window().make();
            brave.windows[0].activeTab.url = "{first_url}";
            ''')
            time.sleep(0.5)
            # Add remaining tabs to this new window (which is now windows[0])
            for tab in tabs[1:]:
                url = tab.get("url", "about:blank")
                run_jxa(f'''
                const brave = Application("Brave Browser");
                brave.Tab({{url: "{url}"}}).make({{at: brave.windows[0]}});
                ''')
                time.sleep(0.2)

        # Position this window — it is always windows[0] (frontmost) right now
        # Use AppleScript bounds format: {left, top, right, bottom}
        if "boundsRaw" in bw:
            br = bw["boundsRaw"]
            run_osascript(f'''
            tell application "Brave Browser"
                set bounds of window 1 to {{{br.get("x",0)}, {br.get("y",0)}, {br.get("width",800)}, {br.get("height",600)}}}
            end tell
            ''')
        else:
            bnd = bw.get("bounds", {})
            run_osascript(f'''
            tell application "Brave Browser"
                set bounds of window 1 to {{{bnd.get("x",0)}, {bnd.get("y",0)}, {bnd.get("x",0) + bnd.get("width",800)}, {bnd.get("y",0) + bnd.get("height",600)}}}
            end tell
            ''')

        # Set active tab on this window (still frontmost = window 1 / windows[0])
        if active_idx and active_idx > 0:
            run_jxa(f'''
            const brave = Application("Brave Browser");
            brave.windows[0].activeTabIndex = {active_idx};
            ''')

        # Brief pause, then move on to next window
        # The next iteration creates a NEW window which becomes windows[0],
        # pushing this one to windows[1], etc. So each iteration always
        # works on windows[0].
        time.sleep(0.3)
    print("  ✓ Brave Browser windows restored")

# --- Restore VS Code windows ---
vscode_windows = layout["windows"].get("vscode", [])
if vscode_windows:
    print(f"📝 Restoring {len(vscode_windows)} VS Code window(s)...")
    recent_workspaces = layout.get("vscodeRecentWorkspaces", [])

    for vw in vscode_windows:
        workspace = vw.get("workspace", "")
        b = vw.get("bounds", {})

        # Priority 1: Use the enriched workspacePath (actual folder path from VS Code state)
        workspace_path = vw.get("workspacePath", "")

        # Priority 2: Fall back to matching workspace name against recent workspaces
        if not workspace_path and workspace:
            for rw in recent_workspaces:
                if workspace.lower() in rw.lower():
                    workspace_path = rw
                    break

        if workspace_path:
            subprocess.Popen(["code", workspace_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        else:
            subprocess.Popen(["code"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        time.sleep(1.5)

        # Position the window
        run_jxa(f'''
        const se = Application("System Events");
        try {{
            const proc = se.processes.byName("Code");
            const w = proc.windows[0];
            w.position = [{b.get("x",0)}, {b.get("y",0)}];
            w.size = [{b.get("width",800)}, {b.get("height",600)}];
        }} catch(e) {{}}
        ''')
        time.sleep(0.5)
    print("  ✓ VS Code windows restored")

# --- Restore Preview (PDF) windows ---
preview_windows = layout["windows"].get("preview", [])
if preview_windows:
    print(f"📄 Restoring {len(preview_windows)} Preview window(s)...")
    for pw in preview_windows:
        path = pw.get("path", "")
        b = pw.get("boundsRaw", pw.get("bounds", {}))
        if path and os.path.isfile(path):
            subprocess.Popen(["open", "-a", "Preview", path],
                           stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            time.sleep(1)
            # Position the window
            if "boundsRaw" in pw:
                br = pw["boundsRaw"]
                run_osascript(f'''
                tell application "Preview"
                    set bounds of window 1 to {{{br.get("x",0)}, {br.get("y",0)}, {br.get("width",800)}, {br.get("height",600)}}}
                end tell
                ''')
            else:
                run_osascript(f'''
                tell application "Preview"
                    set bounds of window 1 to {{{b.get("x",0)}, {b.get("y",0)}, {b.get("x",0) + b.get("width",800)}, {b.get("y",0) + b.get("height",600)}}}
                end tell
                ''')
    print("  ✓ Preview windows restored")

# --- Restore other generic windows ---
other_windows = layout["windows"].get("other", [])
if other_windows:
    # Group by app name
    apps = {}
    for ow in other_windows:
        app_name = ow.get("app", "")
        if app_name:
            apps.setdefault(app_name, []).append(ow)

    for app_name, wins in apps.items():
        print(f"🔲 Restoring {len(wins)} {app_name} window(s)...")
        # Launch the app
        run_osascript(f'tell application "{app_name}" to activate')
        time.sleep(1)
        # Position windows
        for i, ow in enumerate(wins):
            b = ow.get("bounds", {})
            run_jxa(f'''
            const se = Application("System Events");
            try {{
                const proc = se.processes.byName("{app_name}");
                if (proc.windows.length > {i}) {{
                    const w = proc.windows[{i}];
                    w.position = [{b.get("x",0)}, {b.get("y",0)}];
                    w.size = [{b.get("width",800)}, {b.get("height",600)}];
                }}
            }} catch(e) {{}}
            ''')
        time.sleep(0.3)
    print("  ✓ Other windows restored")

print()
print("✅ Layout restored! You may need to fine-tune a few positions if your screen arrangement changed.")
PYEOF
}


