        [[ -z "${2:-}" ]] && { echo -e "${RED}Usage: layout delete <name>${NC}"; exit 1; }
        do_delete "$2"
        ;;
    screens|displays)
        do_screens
        ;;
    "")
        do_interactive
        ;;
    *)
        usage
        ;;
esac
