    local idx=0

    echo -e "  ${CYAN}Saved Layouts:${NC}"

    for f in "$LAYOUT_DIR"/*.json; do
        [[ -f "$f" ]] || continue
        idx=$((idx + 1))

        local entry
        entry=$(/usr/bin/python3 << PYEOF
