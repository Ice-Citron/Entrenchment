idx = $idx
with open("$f") as fh:
    layout = json.loads(fh.read())
name = layout.get("name", os.path.basename("$f").replace(".json",""))
desc = layout.get("description", "")
saved = layout.get("savedAt", "unknown")[:19].replace("T", " ")
screens = layout.get("screenCount", "?")
total = sum(len(v) for v in layout.get("windows", {}).values())
